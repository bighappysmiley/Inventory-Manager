rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Email-domain / super-admin auto-bootstrap, mirrors ensureAdminBootstrap() in app.js.
    function isAutoBootstrapEligible() {
      return signedIn()
        && request.auth.token.email != null
        && (request.auth.token.email.lower() == 'hf@bighappysmiley.com'
            || request.auth.token.email.lower().matches('.*@bighappysmiley\\.com$'));
    }

    // ---------------------------------------------------------
    // Per-user inventory data — fully isolated, owner-only.
    // users/{uid}/items/{itemId}
    // users/{uid}/shelves/{shelfId}
    // users/{uid}/meta/{docId}  (settings doc holds mapLayout)
    // ---------------------------------------------------------
    match /users/{uid} {
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // ---------------------------------------------------------
    // users_meta/{uid} — profile/config doc.
    // Readable by any signed-in user (needed for username-uniqueness checks
    // at registration/rename, and for the admin user directory). Only the
    // user themself may write their own doc — admins manage roles via the
    // separate `admins` collection, never by editing another user's profile.
    // ---------------------------------------------------------
    match /users_meta/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid);
    }

    // ---------------------------------------------------------
    // admins/{uid} — role-membership flags.
    // - Any signed-in user may check/read their own doc (to learn their own
    //   admin status); admins may read/list the whole collection.
    // - A user may create their OWN doc only via the auto-bootstrap path
    //   (super-admin email or company domain), matching ensureAdminBootstrap().
    // - Existing admins may grant/revoke admin access for any OTHER user.
    // - No one may delete their own admin doc (defense-in-depth backing the
    //   client-side "can't remove your own admin access" guard).
    // ---------------------------------------------------------
    match /admins/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(uid) && isAutoBootstrapEligible()) || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin() && request.auth.uid != uid;
    }

    // ---------------------------------------------------------
    // support_tickets/{ticketId} (+ replies subcollection)
    // Any signed-in user may open a ticket and read/reply on their OWN
    // tickets. Admins may read/reply on every ticket and are the only
    // ones who can change a ticket's status.
    // ---------------------------------------------------------
    match /support_tickets/{ticketId} {
      function isTicketOwner() {
        return signedIn() && resource.data.authorUid == request.auth.uid;
      }

      allow read: if isAdmin() || isTicketOwner();
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'open';
      // Admins can change anything (status, etc). The ticket owner may only
      // bump updatedAt (e.g. when posting a reply) on a ticket that isn't
      // already closed — they can never change status or reassign the ticket.
      allow update: if isAdmin()
        || (isTicketOwner()
            && resource.data.status != 'closed'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt']));
      allow delete: if false;

      match /replies/{replyId} {
        function parentTicket() {
          return get(/databases/$(database)/documents/support_tickets/$(ticketId)).data;
        }
        function isParentTicketOwner() {
          return signedIn() && parentTicket().authorUid == request.auth.uid;
        }

        allow read: if isAdmin() || isParentTicketOwner();
        allow create: if parentTicket().status != 'closed'
          && request.resource.data.authorUid == request.auth.uid
          && (
            (isAdmin() && request.resource.data.isAdmin == true)
            || (isParentTicketOwner() && request.resource.data.isAdmin == false)
          );
        allow update, delete: if false;
      }
    }
  }
}
